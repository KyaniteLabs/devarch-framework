#!/usr/bin/env bash
#
# Pre-push hook for dev-archaeology
# Blocks push if audit fails or parity is broken
#

set -e

echo "🔍 Running pre-push checks..."
echo ""

# Run audit with fail-on HIGH
echo "1️⃣  Running audit (HIGH severity blocks push)..."
if ! python3 -m archaeology.cli audit liminal --fail-on HIGH; then
    echo ""
    echo "❌ Audit failed with HIGH or CRITICAL findings"
    echo "   Please fix all blocking issues before pushing"
    exit 1
fi
echo "✓ Audit passed"
echo ""

# Check framework parity
echo "2️⃣  Checking framework parity..."
if ! python3 scripts/sync/check_parity.py; then
    echo ""
    echo "❌ Framework parity check failed"
    echo "   Please sync changes to devarch-framework"
    echo "   Run: python3 scripts/sync/check_parity.py for details"
    exit 1
fi
echo "✓ Parity check passed"
echo ""

echo "✅ All pre-push checks passed"
exit 0
