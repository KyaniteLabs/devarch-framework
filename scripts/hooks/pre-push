#!/usr/bin/env bash
#
# Pre-push hook for devarch-framework
# Blocks push if audit fails or parity is broken
#

set -e

echo "🔍 Running pre-push checks..."
echo ""

# Run audit on demo project with fail-on HIGH
echo "1️⃣  Running audit (HIGH severity blocks push)..."
if ! python3 -m archaeology.cli audit demo-archaeology --fail-on HIGH; then
    echo ""
    echo "❌ Audit failed with HIGH or CRITICAL findings"
    echo "   Please fix all blocking issues before pushing"
    exit 1
fi
echo "✓ Audit passed"
echo ""

echo "✅ All pre-push checks passed"
exit 0
